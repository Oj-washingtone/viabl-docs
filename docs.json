{
    "name": "viabl",
    "url": "https://docs.viabl.dev",
    "basePath": "/docs",
    "favicon": "/favicon.png",
    "defaultVersion": "v2",
    "logo": {
        "dark": "/logo/dark.svg",
        "light": "/logo/light.svg",
        "href": "https://viabl.dev"
    },
    "colors": {
        "primary": "#ff5800",
        "light": "#ff5800",
        "dark": "#ff7733",
        "background": {
            "dark": "radial-gradient(ellipse 60% 10% at 50% -5%, rgba(255,88,0,0.2), transparent), #0c0d0f",
            "light": "radial-gradient(ellipse 60% 25% at 50% -5%, rgba(255,88,0,0.08), transparent), #ffffff"
        },
        "anchors": {
            "from": "#ff5800",
            "to": "#ff5800"
        }
    },
    "font": {
        "headings": {
            "family": "Geist",
            "url": "https://cdn.jsdelivr.net/npm/geist@1.3.0/dist/fonts/geist-sans/style.css"
        },
        "body": {
            "family": "Geist",
            "url": "https://cdn.jsdelivr.net/npm/geist@1.3.0/dist/fonts/geist-sans/style.css"
        }
    },
    "search": {
        "prompt": "Search doc..."
    },
    "topbarCtaButton": {
        "name": "Get Started",
        "url": "/welcome-to-viabl",
        "style": "fill",
        "arrow": true,
        "icon": "Rocket",
        "blank": false
    },
    "navigation": [
        {
            "group": "Getting Started",
            "icon": "Rocket",
            "pages": [
                "quickstart/welcome-to-viabl",
                "quickstart/quickstart",
                "quickstart/configuration",
                "quickstart/writing-pages"
            ]
        },
        {
            "group": "Components",
            "icon": "Layers",
            "pages": [
                "components/overview",
                "components/cards",
                "components/steps",
                "components/accordion",
                "components/tabs",
                "components/callouts",
                "components/badge",
                "components/image",
                "components/tooltip",
                "components/expandable",
                "components/update",
                "components/response-fields"
            ]
        },
        {
            "group": "Deployment",
            "icon": "Cloud",
            "pages": [
                "deployment/overview",
                {
                    "group": "Guides",
                    "pages": [
                        "deployment/docker",
                        "deployment/github-actions"
                    ]
                }
            ]
        }
    ],
    "footerSocials": {
        "twitter": "https://twitter.com/viablkit",
        "github": "https://github.com/Oj-washingtone/viabl-cli",
        "linkedin": "https://linkedin.com/company/viablkit",
        "website": "https://viabl.dev",
        "discord": "https://discord.gg/JyBMrk4G"
    },
    "seo": {
        "indexHiding": false,
        "og": {
            "title": "Viabl documentation",
            "description": "Ship Documentation easily with viabl",
            "image": "/images/hero-white.png"
        }
    },
    "feedback": {
        "thumbsRating": true,
        "suggestEdit": true,
        "raiseIssue": true,
        "webhook": "http://where-the-feedback-will-go-to",
        "githubRepo": "https://github.com/Oj-washingtone/viabl-docs"
    }
}